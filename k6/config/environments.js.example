// Copy to environments.js and fill in values
// k6/config/environments.js is gitignored

export const ENVS = {
  dev: {
    baseUrl: 'http://<DEV_IP>:18000',
    tenant: 'statea.citya',
    stateTenant: 'statea',
    username: __ENV.DIGIT_USERNAME || 'ADMIN',
    password: __ENV.DIGIT_PASSWORD || 'eGov@123',
    // Optional: override PGR ServiceDefs used in load tests.
    // Omit to use all 33 default service codes (requires full-dump.sql data).
    // For minimal/k8s deployments with only default-data-handler bootstrap data:
    // serviceCodes: [
    //   'StreetLightNotWorking', 'NoStreetlight', 'GarbageNeedsTobeCleared',
    //   'BurningOfGarbage', 'DamagedGarbageBin', 'NonSweepingOfRoad',
    // ],
  },
  prod: {
    baseUrl: 'http://<PROD_IP>:18000',
    tenant: 'statea.citya',
    stateTenant: 'statea',
    username: __ENV.DIGIT_USERNAME || 'ADMIN',
    password: __ENV.DIGIT_PASSWORD || 'eGov@123',
  },
};

export function getEnv() {
  const target = __ENV.TARGET || 'dev';
  const env = ENVS[target];
  if (!env) {
    throw new Error(`Unknown target: ${target}. Use TARGET=dev or TARGET=prod`);
  }
  return env;
}
